{
  "name": "bloomide-electron",
  "version": "1.0.0",
  "description": "BloomIDE — AI-native desktop IDE (Electron shell)",
  "main": "main.js",
  "author": "BloomIDE",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"cross-env BROWSER=none yarn --cwd ../frontend start\" \"wait-on http://localhost:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "io.bloomide.app",
    "productName": "BloomIDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "../frontend/build/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "mac": { "category": "public.app-category.developer-tools", "target": ["dmg", "zip"] },
    "win": { "target": ["nsis", "portable"] },
    "linux": { "target": ["AppImage", "deb"], "category": "Development" }
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "wait-on": "^8.0.0"
  }
}
